from functools import partial
import gradio as gr
import os
from groq import Groq


client = Groq(api_key=os.environ["groqapi"])

def respond(message, history, system_prompt, temperature):
  messages = []
  if system_prompt:
    messages.append({"role": "system", "content": system_prompt})

  
  for turn in history:
    
    filtered_turn = {k: v for k, v in turn.items() if k in ['role', 'content']}
    messages.append(filtered_turn)

  messages.append({"role": "user", "content": message})

  response = client.chat.completions.create(
    model="llama-3.1-8b-instant",
    messages=messages,
    temperature=temperature,
    stream=True,
  )
  partial_response = ""
  for chunk in response:
    if chunk.choices[0].delta.content is not None:
      partial_response += chunk.choices[0].delta.content
      yield partial_response

default_system_prompt = "You are an artificial intelligence expert with experience in every aspect of AI rules and regulations, including the history of AI."
default_temperature = 0.7 # A reasonable default for creative tasks


system_prompt_input = gr.Textbox(
    label="System Prompt",
    value=default_system_prompt,
    lines=3,
    placeholder="Define the chatbot's personality and role here..."
)
temperature_slider = gr.Slider(
    minimum=0.0,
    maximum=1.0,
    step=0.1,
    value=default_temperature,
    label="Temperature (randomness)"
)

demo = gr.ChatInterface(
    fn=respond,
    chatbot=gr.Chatbot(height=300),
    textbox=gr.Textbox(placeholder="Ask me anything about AI...", container=False, scale=7),
    title="AI Expert Chatbot",
    description="A chatbot that answers questions about AI, with customizable personality and randomness.",
    theme="soft",
    # Update examples to include system_prompt and temperature for each example
    examples=[
        ["What is machine learning?", default_system_prompt, default_temperature],
        ["Explain deep learning.", default_system_prompt, default_temperature],
        ["Who are some pioneers in AI history?", default_system_prompt, default_temperature]
    ],
    cache_examples=True,
    additional_inputs=[system_prompt_input, temperature_slider],
    type="messages"
)
demo.launch(debug=True)
